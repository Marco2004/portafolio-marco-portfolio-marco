# Secretos y config local — nunca se suben al repo.
.env

# Volcados de la base de datos: incluyen password_hash y tokens reales de
# admin_users, no deben terminar en un repo público (database/.htaccess ya
# los bloquea por HTTP, esto los bloquea también para git).
database/backups/*.sql

# Logs de seguridad generados en tiempo de ejecución.
src/logs/*.log

# Archivos subidos por el admin desde el dashboard (contenido, no código).
public/uploads/projects/*
!public/uploads/projects/.gitkeep

# Artefactos de editor/SO.
.DS_Store
Thumbs.db
.vscode/
.idea/

# Estado interno de Claude Code (sesiones/locks) — herramienta, no proyecto.
.claude/

# Guía para Claude Code sobre las convenciones del proyecto (arquitectura,
# reglas de seguridad no negociables, comandos) — instrucciones para trabajar
# en el repo, no código ni contenido del proyecto en sí, así que no se sube.
CLAUDE.md

# Pruebas E2E (Playwright/Python, ver tests/e2e/README.md): la sesión
# guardada trae cookies reales (gate/login), y __pycache__ es un artefacto
# de Python, ninguno de los dos debe terminar en el repo.
tests/e2e/.admin_storage_state.json
tests/e2e/.qa_storage_state.json
tests/e2e/__pycache__/

# Ningún .php debe volver a vivir bajo tests/: un script PHP ahí (ver
# auditoría de seguridad) quedaba ejecutable por HTTP sin autenticación
# porque tests/ nunca tuvo el mismo .htaccess de "Require all denied" que
# ya protege src/, database/ e i18n/ (ahora sí lo tiene, ver tests/.htaccess
# — esto es una segunda capa por si algún día falta AllowOverride en el
# hosting). Los scripts .py de Playwright nunca necesitan ejecutarse vía
# Apache, así que no hace falta excluirlos a ellos.
tests/**/*.php

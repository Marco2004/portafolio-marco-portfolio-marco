# Evita que Apache liste el contenido de una carpeta que no tiene index.php
# (ej. pedir "/public/uploads/projects/" directo, sin nombre de archivo,
# mostraría cada imagen subida en vez de un error). Ya se confirmó por curl
# que el hosting de producción no lista directorios por su cuenta, así que
# esto es una segunda capa, no la única.
# OJO — SI ESTA LÍNEA ROMPE PRODUCCIÓN (Error 500 en todo el sitio): algunos
# hostings compartidos no permiten cambiar "Options" desde .htaccess. Basta
# con borrar la línea "Options -Indexes" de abajo (nada más) — el resto del
# archivo sigue funcionando exactamente igual sin ella.
Options -Indexes

# Sirve el sitio público (public/) en la raíz del dominio, sin tener que
# escribir "/public" en la URL — para que en producción baste con
# "https://midominio.com/" en vez de "https://midominio.com/public/". Es una
# reescritura interna (el navegador nunca ve "/public"), no una redirección:
# admin/, api/, src/, database/ e i18n/ mantienen sus rutas reales tal cual,
# igual que "/public/..." directo (lo sigue usando admin/index.php para el
# iframe de vista previa y el link "Ver sitio público").
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Raíz del sitio (con o sin "/" final) → sitio público, sin "/public" en
    # la URL. Va antes que la regla de abajo porque la carpeta del proyecto
    # en sí también es "una ruta real" (-d) y si no, nunca llegaría aquí.
    RewriteRule ^$ public/index.php [L]

    # Ya existe como archivo o carpeta real (admin/, api/, src/, database/,
    # i18n/, public/, dotfiles...) — se sirve tal cual, sin reescribir nada.
    # %{REQUEST_FILENAME} es la ruta absoluta ya resuelta por Apache, así que
    # esto funciona igual si el proyecto vive en la raíz del dominio
    # (producción) que si vive en una subcarpeta de htdocs (XAMPP local).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Cualquier otra ruta que no exista arriba pero sí exista dentro de
    # public/ (assets/css/*, assets/js/*, uploads/*, referenciadas con ruta
    # relativa desde public/index.php) se sirve desde ahí. El (?!public/)
    # evita reescribir dos veces una ruta que ya empieza con "public/" pero no
    # existe (ej. una imagen subida y luego borrada) — sin él, esa ruta
    # entraría en un bucle "public/public/public/..." hasta el límite de
    # redirecciones internas de Apache (error 500).
    RewriteRule ^(?!public/)(.+)$ public/$1 [L]
</IfModule>

# Bloquea el acceso HTTP directo a cualquier "dotfile" en la raíz del sitio
# (.env, .gitignore, .git/, etc.) — .env vive aquí porque config.php lo lee
# con una ruta relativa simple, pero NUNCA debe poder descargarse por HTTP:
# contiene las credenciales reales de SMTP/BD (ver src/config.php).
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
    # Fuerza HTTPS en el navegador durante 1 año (incluidos subdominios) para
    # cualquier visita futura, incluso si alguien escribe "http://" a mano o
    # sigue un link viejo — sin esto, esa primera petición viaja en claro
    # antes de que el 301 a HTTPS (ya configurado más abajo) pueda actuar.
    # Seguro de activar: el sitio ya fuerza HTTPS en producción.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # Aísla la pestaña de este sitio de otras que la hayan abierto con
    # window.open() (protección adicional contra ataques tipo
    # "reverse tabnabbing"/Spectre entre pestañas de distintos orígenes) — no
    # afecta la navegación normal ni los links con target="_blank" (que ya
    # usan rel="noopener" en todo el sitio).
    Header always set Cross-Origin-Opener-Policy "same-origin"
    # Este sitio no publica ningún crossdomain.xml/clientaccesspolicy.xml para
    # Flash/Silverlight (tecnologías obsoletas) — lo declara explícito en vez
    # de dejarlo ambiguo.
    Header always set X-Permitted-Cross-Domain-Policies "none"
    # Ya no hay 'unsafe-inline' en script-src: todo el JS que vivía inline en
    # <script> se movió a archivos .js estáticos (ver
    # admin/assets/js/theme-antiflash.js, admin/assets/js/admin-preview-init.js,
    # public/assets/js/theme-antiflash.js, public/assets/js/mark-js-enabled.js),
    # verificado con Playwright (0 violaciones de script-src en sitio público,
    # login y setup) — un <script> inyectado por una vulnerabilidad futura (que
    # hoy no existe: toda salida ya pasa por e()/escapeHtml()) ya no se
    # ejecutaría.
    #
    # style-src SÍ conserva 'unsafe-inline' a propósito: aunque los style=""
    # estáticos del HTML ya se movieron a clases CSS, muchos scripts (fades de
    # tema/idioma, apertura del CV, el diálogo de confirmación con partículas,
    # arrastrar para reordenar, la vista previa de imagen recién subida)
    # calculan valores en tiempo real (posiciones, colores de transición, la
    # URL de la imagen que el admin acaba de subir) y los aplican con
    # elemento.style.propiedad = valor — para la CSP eso cuenta exactamente
    # igual que un style="" en el HTML. Se probó quitando 'unsafe-inline' de
    # style-src también: rompió esas animaciones (cientos de violaciones reales
    # con Playwright). Convertir esos valores dinámicos a clases fijas no es
    # posible sin reescribir esa lógica (una URL de imagen subida, por
    # ejemplo, no se puede declarar de antemano como clase CSS) — se deja
    # fuera para no arriesgar la funcionalidad/animaciones actuales.
    #
    # frame-ancestors 'self' (antes 'none'): el dashboard embebe el sitio
    # público real dentro de un <iframe> para la vista previa en vivo (ver
    # admin/assets/js/admin-preview.js) — sigue bloqueando que cualquier
    # sitio de terceros lo enmarque (clickjacking), solo permite que el
    # propio dominio se enmarque a sí mismo.
    Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self'; frame-ancestors 'self'"
</IfModule>

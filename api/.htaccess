# Refuerzo específico para /api — segunda capa, no la única: el .htaccess de
# la raíz ya bloquea listar directorios y cualquier dotfile en todo el sitio
# (ver comentarios ahí). Si algún hosting no hereda "Options -Indexes" del
# .htaccess raíz para subcarpetas (AllowOverride limitado, vhost propio,
# etc.), esta línea lo garantiza también aquí sin depender de eso.
Options -Indexes

# Bloquea servir por HTTP cualquier archivo de respaldo/editor que pudiera
# quedar suelto en esta carpeta — nunca debería pasar, pero si pasa, no debe
# quedar descargable en texto plano.
<FilesMatch "\.(bak|old|orig|sql|log|swp|swo)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

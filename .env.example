# Copia este archivo a ".env" (mismo directorio) y rellena tus propios valores.
# ".env" nunca se sube a git (ver .gitignore) — "config.php" lo lee en tiempo
# de ejecución y cae de regreso a estos defaults solo cuando una variable no
# está definida.

DB_HOST=127.0.0.1
DB_NAME=portafolio
DB_USER=root
DB_PASS=

# Brevo (https://www.brevo.com) — plan gratuito: 300 correos/día, sin tarjeta.
# Se usa su API HTTP (no SMTP) porque muchos hosts gratuitos (Google Cloud,
# etc.) bloquean los puertos SMTP salientes pero nunca el puerto 443/HTTPS.
# 1. Crea una cuenta gratis y verifica un "remitente individual" (tu correo).
# 2. Genera una API key en Panel > SMTP & API > API Keys.
# 3. Pégala abajo. MAIL_FROM_EMAIL debe ser el correo que verificaste.
BREVO_API_KEY=
MAIL_FROM_EMAIL=tu-correo@gmail.com
MAIL_FROM_NAME=Portafolio Web

SITE_NAME=Portafolio Web

# Dominio público real del sitio en producción, SIN "/" al final (ej.
# https://midominio.com). Usado para construir los links de recuperación de
# contraseña/verificación de correo sin depender del Host de la petición.
# Déjalo vacío en desarrollo local.
SITE_URL=

# Clave secreta para poder abrir /admin en producción — sin ella todo
# /admin/* responde 404 (ver require_admin_gate() en src/auth.php). Genera
# una cadena larga y aleatoria propia, ej. con:
#   php -r "echo bin2hex(random_bytes(20));"
# y guárdala en un lugar seguro: es lo que hace que nadie más que tú sepa que
# el panel existe. Déjala vacía en desarrollo local (no bloquea nada en XAMPP).
ADMIN_ACCESS_KEY=
